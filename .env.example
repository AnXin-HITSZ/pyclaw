# Copy this file to .env and fill in your real values.
# Never commit .env.

# -----------------------------------------------------------------------------
# pyclaw API
# -----------------------------------------------------------------------------
# Optional local env file override. In most cases keep the default .env.
# OPENCLAW_ENV_FILE=.env

# Required when the HTTP API should reject unauthenticated /v1/agent/run calls.
PYCLAW_API_TOKEN=

# Transcript/session data directory.
OPENCLAW_CHATDATA_DIR=chatdata

# -----------------------------------------------------------------------------
# LLM provider
# -----------------------------------------------------------------------------
OPENAI_API_KEY=

# Optional overrides. OPENAI_BASE_URL is also used for OpenAI-compatible gateways.
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_ORGANIZATION=
# OPENAI_PROJECT=
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_API_MODE=responses

# Use chat_completions for OpenAI-compatible providers such as DeepSeek.
# OPENAI_API_MODE=chat_completions

# -----------------------------------------------------------------------------
# Channel Agent runtime
# -----------------------------------------------------------------------------
# These settings control the Agent turn triggered by WeChat/Feishu webhooks.
OPENCLAW_CHANNEL_PROVIDER=openai
# OPENCLAW_CHANNEL_MODEL=
# OPENCLAW_CHANNEL_SYSTEM=
OPENCLAW_CHANNEL_API_MODE=auto
# OPENCLAW_CHANNEL_CHATDATA_DIR=chatdata/channels
OPENCLAW_CHANNEL_TOOL_PROFILE=messaging
OPENCLAW_CHANNEL_SHELL_APPROVAL=deny
OPENCLAW_CHANNEL_WEBHOOK_SYNC=false

# -----------------------------------------------------------------------------
# Ingress queue
# -----------------------------------------------------------------------------
# MySQL is the only supported durable ingress queue backend.
OPENCLAW_INGRESS_QUEUE_DSN=mysql+pymysql://pyclaw:CHANGE_ME@pyclaw-mysql:3306/pyclaw?charset=utf8mb4&table=ingress_queue
OPENCLAW_INGRESS_QUEUE_STALE_AFTER_SECONDS=300

# -----------------------------------------------------------------------------
# WeChat channel
# -----------------------------------------------------------------------------
OPENCLAW_WECHAT_ENABLED=false
OPENCLAW_WECHAT_NAME=wechat
OPENCLAW_WECHAT_REPLY_MODE=passive_xml
# OPENCLAW_WECHAT_PASSIVE_REPLY_TIMEOUT_SECONDS=4.5
# OPENCLAW_WECHAT_PASSIVE_REPLY_FALLBACK_TEXT=Received. Processing.
# OPENCLAW_WECHAT_ACCOUNT_ID=
# OPENCLAW_WECHAT_TOKEN=
# OPENCLAW_WECHAT_APP_ID=
# OPENCLAW_WECHAT_APP_SECRET=
# OPENCLAW_WECHAT_ACCESS_TOKEN=
# OPENCLAW_WECHAT_API_BASE_URL=https://api.weixin.qq.com

# -----------------------------------------------------------------------------
# Feishu channel
# -----------------------------------------------------------------------------
OPENCLAW_FEISHU_ENABLED=false
OPENCLAW_FEISHU_NAME=feishu
OPENCLAW_FEISHU_REPLY_MODE=async_worker
# OPENCLAW_FEISHU_ACCOUNT_ID=
# OPENCLAW_FEISHU_APP_ID=
# OPENCLAW_FEISHU_APP_SECRET=
# OPENCLAW_FEISHU_VERIFICATION_TOKEN=
# OPENCLAW_FEISHU_SIGN_SECRET=
# OPENCLAW_FEISHU_ENCRYPT_KEY=  # reserved; encrypted Feishu payloads are not implemented yet.
# OPENCLAW_FEISHU_TENANT_ACCESS_TOKEN=
# OPENCLAW_FEISHU_API_BASE_URL=https://open.feishu.cn
